# ─────────────────────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────────────────────

# URL de base de l'API Laravel (non secrète — utilisée aussi côté client)
NEXT_PUBLIC_API_BASE_URL=https://api.cosflow.co

# OAuth Client Credentials Laravel Passport (SERVER-SIDE ONLY — jamais NEXT_PUBLIC_)
API_CLIENT_ID=your-client-id-here
API_CLIENT_SECRET=your-client-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────

# URL publique de l'application (utilisée pour meta tags, redirections Open Graph)
NEXT_PUBLIC_APP_URL=https://cosflow.co

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────────────────────────────────────────

# Clé Bugsnag pour le tracking d'erreurs (initialisé uniquement en production)
BUGSNAG_API_KEY=your-bugsnag-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# CDN Images
# ─────────────────────────────────────────────────────────────────────────────

# Domaine CloudFront pour les images (next/image remotePatterns)
CLOUDFRONT_DOMAIN=d1f4vr4f1px6z.cloudfront.net
